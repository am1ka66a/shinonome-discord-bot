# 複製此檔為 .env 並填入真實數值。不要把 .env 上傳到 GitHub！
DISCORD_TOKEN=你的_Bot_令牌

# 方式 A：一條網址（主機、帳密、庫名都在裡面）
# MYSQL_URL=mysql://使用者:密碼@主機:3306/資料庫名稱

# 方式 B：分開寫（與 A 二選一即可）
# MYSQLHOST=127.0.0.1
# MYSQLPORT=3306
# MYSQLUSER=你的使用者
# MYSQLPASSWORD=你的密碼
# MYSQLDATABASE=你的資料庫名稱

# 選用：台股 API 若憑證有問題要略過 SSL 可設為 1（預設 0，需自行評估風險）
# STOCK_API_INSECURE_SSL=0
